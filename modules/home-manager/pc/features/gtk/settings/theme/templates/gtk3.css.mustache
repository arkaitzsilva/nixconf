@define-color window_bg_color #{{base01-hex}};
@define-color window_fg_color #{{base05-hex}};
@define-color view_bg_color #{{base00-hex}};
@define-color view_fg_color #{{base06-hex}};
@define-color accent_bg_color #{{base0C-hex}};
@define-color accent_fg_color #{{base06-hex}};
@define-color headerbar_bg_color #{{base02-hex}};
@define-color headerbar_fg_color #{{base06-hex}};
@define-color headerbar_backdrop_color @window_bg_color;
@define-color popover_bg_color #{{base03-hex}};
@define-color popover_fg_color @view_fg_color;
@define-color dialog_bg_color #{{base03-hex}};
@define-color dialog_fg_color @view_fg_color;
@define-color card_bg_color #{{base03-hex}};
@define-color card_fg_color @view_fg_color;
@define-color sidebar_bg_color #{{base02-hex}};
@define-color sidebar_fg_color #{{base06-hex}};
@define-color sidebar_backdrop_color @window_bg_color;
@define-color sidebar_shade_color rgba(0,0,0,0.25);
@define-color sidebar_border_color rgba(0, 0, 0, 0.36);
@define-color destructive_bg_color #{{base08-hex}};
@define-color success_bg_color #{{base0B-hex}};
@define-color warning_bg_color #{{base0A-hex}};
@define-color error_bg_color #{{base08-hex}};
decoration {
  box-shadow: 0 3px 12px 1px rgba(0, 0, 0, 0.7), 0 0 0 1px mix(#{{base06-hex}},@window_bg_color,0.9);
}
decoration:backdrop {
  box-shadow: 0 3px 12px 1px transparent, 0 2px 6px 2px rgba(0, 0, 0, 0.4), 0 0 0 1px mix(#{{base06-hex}},@window_bg_color,0.95);
}
.tiled decoration, .tiled-top decoration, .tiled-bottom decoration, .tiled-right decoration, .tiled-left decoration {
  box-shadow: 0 0 0 1px mix(#{{base06-hex}},@window_bg_color,0.95), 0 0 0 20px transparent;
}
messagedialog.csd decoration, .csd.popup decoration, .maximized .csd.popup decoration {
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.8), 0 0 0 1px alpha(mix(#{{base06-hex}},@window_bg_color,0.9),0.9);
}
tooltip.csd decoration {
  box-shadow: none;
}
.maximized decoration, .fullscreen decoration {
  border-radius: 0;
  box-shadow: none;
}
.ssd decoration {
  box-shadow: 0 0 0 1px mix(#{{base06-hex}},@window_bg_color,0.9);
}
.ssd decoration:backdrop {
  box-shadow: 0 0 0 1px mix(#{{base06-hex}},@window_bg_color,0.95);
}
.ssd.maximized decoration, .ssd.maximized decoration:backdrop {
  box-shadow: none;
}
.solid-csd decoration {
  box-shadow: inset 0 0 0 5px alpha(currentColor,0.5), inset 0 0 0 4px @headerbar_bg_color, inset 0 0 0 1px alpha(currentColor,0.5);
}
.solid-csd decoration:backdrop {
  box-shadow: inset 0 0 0 3px @window_bg_color;
}
